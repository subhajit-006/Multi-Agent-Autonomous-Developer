# ============================================================================
# MAAD Multi-Agent Autonomous Developer - N8N Integrated Configuration
# ============================================================================

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# FastAPI & CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5678

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_N8N_URL=http://localhost:5678

# ============================================================================
# Per-Agent Model Configuration
# ============================================================================
# Using OpenRouter free-tier models for cost-effective automation
# Switch to paid models as needed (claude-3-sonnet, gpt-4, etc.)

# Planner Agent - Creates development plans
# Recommended: Google Gemma 4 (fast, free tier available)
PLANNER_MODEL=google/gemma-4-26b-a4b-it:free

# Architect Agent - Designs system architecture
# Recommended: Meta Llama 3 70B (best reasoning, free tier available)
ARCHITECT_MODEL=meta-llama/llama-3-70b-instruct:free

# Developer Agent - Writes production code
# Recommended: Google Gemma 4 (best code generation, free tier available)
DEVELOPER_MODEL=google/gemma-4-26b-a4b-it:free

# Debugger Agent - Reviews and fixes code
# Recommended: Meta Llama 3 8B (lightweight, fast review, free tier available)
DEBUGGER_MODEL=meta-llama/llama-3-8b-instruct:free

# Tester Agent - Generates test cases and validates code
# Recommended: Google Gemma 4 (good test generation)
TESTER_MODEL=google/gemma-4-26b-a4b-it:free

# ============================================================================
# Alternative Premium Models (uncomment to use)
# ============================================================================
# PLANNER_MODEL=anthropic/claude-3-sonnet
# ARCHITECT_MODEL=openai/gpt-4-turbo
# DEVELOPER_MODEL=anthropic/claude-3-opus
# DEBUGGER_MODEL=meta-llama/llama-3-70b-instruct
# TESTER_MODEL=openai/gpt-4

# ============================================================================
# N8N Configuration
# ============================================================================
TIMEZONE=UTC
N8N_USER_MANAGEMENT_DISABLED=true

# ============================================================================
# GitHub Integration (Optional)
# ============================================================================
GITHUB_TOKEN=

# ============================================================================
# Optional: Redis Configuration (for distributed caching)
# ============================================================================
# REDIS_URL=redis://localhost:6379
# REDIS_DB=0

# ============================================================================
# Logging & Debugging
# ============================================================================
LOG_LEVEL=INFO
DEBUG=false

# ============================================================================
# Database Configuration (for session management)
# ============================================================================
DATABASE_URL=sqlite:///./sessions.db

